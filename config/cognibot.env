# ─── CogniBot Environment Config ─────────────────────────────────────
# LLM Provider: gemini | ollama | groq
COGNIBOT_LLM_PROVIDER=ollama

# Model name (provider-specific)
COGNIBOT_LLM_MODEL=ollama:lfm2:latest

# API keys (set the one matching your provider)
GOOGLE_API_KEY=
GROQ_API_KEY=
# For ollama, no API key needed — just set the base URL:
OLLAMA_BASE_URL=http://172.16.84.107:11434/v1

# ─── Paths (defaults work inside Docker) ──────────────────────────────
COGNIBOT_SKILLS_DIR=/app/skills
COGNIBOT_SOUL_PATH=/app/skills/SOUL.md
COGNIBOT_MCP_SERVER_SCRIPT=/app/agenticros/packages/agenticros-claude-code/dist/index.js
AGENTICROS_CONFIG_PATH=/app/config/agenticros.json
